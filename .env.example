# CallGuard Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Hugging Face token ────────────────────────────────────────────────────────
# Required for whisperx diarization (pyannote.audio).
# 1. Create a free account at https://huggingface.co
# 2. Accept the pyannote/speaker-diarization-3.1 model license:
#    https://huggingface.co/pyannote/speaker-diarization-3.1
# 3. Accept the pyannote/segmentation-3.0 model license:
#    https://huggingface.co/pyannote/segmentation-3.0
# 4. Generate a token at https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here

# ── Whisper model size ────────────────────────────────────────────────────────
# Options: tiny, base, small, medium, large-v2, large-v3
# Smaller = faster but less accurate. "base" is good for development.
WHISPER_MODEL=base

# ── Compute device ────────────────────────────────────────────────────────────
# "cpu" works everywhere. "cuda" requires an NVIDIA GPU + CUDA toolkit.
COMPUTE_DEVICE=cpu

# ── Audio settings ────────────────────────────────────────────────────────────
# whisperx expects 16kHz mono WAV. We resample everything to this.
AUDIO_SAMPLE_RATE=16000

# ── Database ──────────────────────────────────────────────────────────────────
# Path to the SQLite database file (relative to project root).
DATABASE_PATH=callguard.db

# ── Keyword list ──────────────────────────────────────────────────────────────
# Path to the JSON file containing threat keywords (relative to project root).
KEYWORDS_PATH=pipeline/keywords.json

# ── Detection thresholds ─────────────────────────────────────────────────────
# Fuzzy match score (0-100). Matches above this are considered hits.
FUZZY_THRESHOLD=80

# Rolling context window: how many prior segments to include for context analysis.
CONTEXT_WINDOW_SIZE=4
